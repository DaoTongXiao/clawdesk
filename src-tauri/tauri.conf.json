{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClawDesk",
  "version": "0.1.2",
  "identifier": "com.chatclaw.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev:desktop-web",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build:desktop-web",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "ClawDesk",
        "width": 1200,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://127.0.0.1:* http://localhost:* ws: wss:;"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": "v1Compatible",
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.png"]
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/DaoTongXiao/clawdesk/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZEMjlFM0I3N0M2MUJDN0YKUldSL3ZHRjh0K01wL1VSQ1BGYklaSjA5eW15QzV2WS82UDhoaTJHSWJDaUJDVG5OajZTVjRLUWkK"
    }
  }
}
